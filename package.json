    "@react-pdf/renderer": "^4.5.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.27.0",
    "fumadocs-core": "^16.4.7",
    "fumadocs-mdx": "^14.2.5",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.562.0",
