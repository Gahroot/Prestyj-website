{
  "name": "prestyj",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "indexnow": "tsx scripts/submit-indexnow.ts",
    "indexnow:dry": "tsx scripts/submit-indexnow.ts --dry-run",
    "wikidata:create": "tsx scripts/wikidata/create-prestyj-item.ts",
    "wikidata:create:dry": "tsx scripts/wikidata/create-prestyj-item.ts",
    "backlinks:snapshot": "tsx scripts/backlinks/snapshot.ts",
    "backlinks:verify": "tsx scripts/backlinks/verify.ts",
    "backlinks:verify:free100": "tsx scripts/backlinks/verify-free-100.ts",
    "backlinks:track": "tsx scripts/backlinks/track-referring-domains.ts",
    "backlinks:track:dry": "tsx scripts/backlinks/track-referring-domains.ts --dry-run",
    "dataset:bundles": "tsx scripts/backlinks/generate-dataset-directory-bundles.ts",
    "dataset:pitch": "tsx scripts/backlinks/pitch-dataset.ts",
    "dataset:pitch:list": "tsx scripts/backlinks/pitch-dataset.ts --list",
    "indexnow:diff": "tsx scripts/indexnow-diff.ts",
    "indexnow:diff:dry": "tsx scripts/indexnow-diff.ts --dry-run",
    "gen-scripts": "tsx scripts/gen-prestyj-promo-scripts.ts",
    "analyze:citations": "tsx scripts/analyze-ai-citations.ts",
    "seo:check-citation-surfaces": "tsx scripts/seo/check-citation-surfaces.ts",
    "seo:find-duplicates": "tsx scripts/seo/find-near-duplicate-pages.ts",
    "seo:gsc-progress": "tsx scripts/seo/record-gsc-progress.ts",
    "seo:gsc-progress:dry": "tsx scripts/seo/record-gsc-progress.ts --dry-run",
    "seo-bot": "tsx scripts/seo-bot/cli.ts"
  },
  "dependencies": {
