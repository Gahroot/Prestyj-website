# Copy this file to .env.local and add your actual values
# NEVER commit .env.local to version control

# IndexNow API Key for search engine indexing
# Get your key from: https://www.bing.com/indexnow
INDEXNOW_API_KEY=your-api-key-here

# ─── Wikidata bot credentials (one-time setup) ───────────────────────────
# Used by scripts/wikidata/create-prestyj-item.ts to create the canonical
# Wikidata entity for Prestyj (DR-95 backlink + AI-engine entity anchor).
#
# Create credentials at https://www.wikidata.org/wiki/Special:BotPasswords
# while logged in to your Wikidata account. Required grants:
#   - High-volume editing
#   - Edit existing pages
#   - Create, edit, and move pages
#
# Username format: YourMainUsername@BotName  (Wikidata combines them)
# Then run: npm run wikidata:create -- --live
WIKIDATA_USERNAME=
WIKIDATA_BOT_PASSWORD=

# Z-Image API Key for media generation
# Used by the /media command to generate brand-aligned imagery
ZIMAGE_API_KEY=your-z-image-api-key-here

# ─── Google Search Console ─────────────────────────────────────
# HTML-tag verification token for Search Console. Required to verify the
# prestyj.com property and track branded-query ("Prestyj") impressions/clicks.
# Get it in Search Console → Add property → HTML tag method: copy ONLY the
# content="..." value (not the full <meta> tag). When unset, no verification
# meta tag is emitted. NEXT_PUBLIC_ so it ships in the static <head>.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─── The Tribunal homepage concierge ─────────────────────────────────────
# Public API base for Prestyj's live homepage voice-agent demo. The browser only
# receives short-lived OpenAI Realtime client secrets minted by The Tribunal.
NEXT_PUBLIC_TRIBUNAL_API_BASE=https://backend-api-production-b536.up.railway.app
# Public embed ID printed by backend/scripts/demo/create_prestyj_homepage_agent.py
# in The Tribunal. Leave blank to show the booking fallback instead of live voice.
NEXT_PUBLIC_TRIBUNAL_HOMEPAGE_AGENT_ID=
# Enables the consent-gated phone-call demo panel when the public embed agent is configured.
NEXT_PUBLIC_TRIBUNAL_PHONE_DEMO_ENABLED=true

# ─── Stripe ──────────────────────────────────────────────────────────────
# Stripe price ID for $497 Starter batch tier (100 ads). Product: prod_UWCSxWJ7AGdDmi
STRIPE_PRICE_STARTER=price_1TXA39KjuiGf4unh2gtO77S8
# Stripe price ID for $1,000 starter→300 order bump. Product: prod_ULgZI1fMlTqy14
STRIPE_PRICE_STARTER_BUMP_TO_300=price_1TXA7WKjuiGf4unhz8F2MFxD
# Stripe Promotion Code ID for the FREE300 founding-cohort coupon.
# This is the `promo_xxx` ID (NOT the customer-facing "FREE300" string).
# Find it in Stripe Dashboard → Products → Coupons → Promotion codes.
STRIPE_PROMO_CODE_FREE300=promo_xxx

# ─── SEO Bot (scripts/seo-bot) ───────────────────────────────────────────
# Set whichever providers you want to use; leave the rest blank.
# The seo-bot will skip any task whose provider is not configured.

# Anthropic (Claude) — recommended for blog posts and comparison pages
ANTHROPIC_API_KEY=

# Google Gemini — free tier covers most daily volume; recommended for high-volume tasks
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# DeepSeek (OpenAI-compatible) — very cheap fallback
# https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Alibaba Qwen via DashScope (OpenAI-compatible) — overseas option
# https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=

# Moonshot Kimi (OpenAI-compatible)
# https://platform.moonshot.ai
MOONSHOT_API_KEY=

# Groq (OpenAI-compatible) — fast Llama hosting
# https://console.groq.com
GROQ_API_KEY=

# OpenRouter (OpenAI-compatible) — single key for many models
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Premium client portal hand-off
# Paid batch-video-ads checkouts redirect to the portal's verified claim flow.
NEXT_PUBLIC_PREMIUM_PORTAL_URL=https://portal.prestyj.com
# Cutover switch for the legacy on-site /intake form. Keep "true" as an
# emergency backup during cutover; set to "false" to disable after the portal
# claim flow is verified end to end.
LEGACY_INTAKE_ENABLED=true
